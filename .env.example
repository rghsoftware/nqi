# Example environment variables. Copy this to a new file named `.env`
# and fill in your details. These are used by docker-compose.yml.

POSTGRES_USER=nqi_user
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=nqi_db
DATABASE_URL="postgres://nqi_user:your_strong_password@localhost:5432/nqi_db?sslmode=disable"
JWT_SECRET_KEY="your-super-secret-jwt-key-that-is-very-long-and-random"
